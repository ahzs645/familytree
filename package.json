{
  "name": "cloudtreeweb-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Reconstructed CloudTreeWeb family tree app from deobfuscated source",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "vite build",
    "preview": "vite preview",
    "patch": "node scripts/patch-bundle.js",
    "copy-wasm": "cp node_modules/sql.js/dist/sql-wasm.js public/ && cp node_modules/sql.js/dist/sql-wasm.wasm public/",
    "extract": "node scripts/extract-mftpkg.js",
    "postinstall": "npm run copy-wasm && npm run patch"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^6.3.2",
    "vitest": "^4.1.4"
  }
}
